<section class="gh-pricing gh-outer">
    <div class="gh-pricing-inner gh-inner">
        {{#get "tiers" include="monthly_price,yearly_price,benefits" limit="50" filter="visibility:public"}}
            {{#if tiers}}
                <div class="gh-pricing-grid">
                    {{#foreach tiers}}
                        <article class="gh-pricing-card">
                            <h2 class="gh-pricing-card-name">{{name}}</h2>
                            {{#if description}}
                                <p class="gh-pricing-card-description">{{description}}</p>
                            {{/if}}

                            <div class="gh-pricing-card-actions">
                                {{#if monthly_price}}
                                    <a class="gh-btn gh-outline-btn" href="#/portal/signup/{{id}}/monthly" data-portal="signup/{{id}}/monthly">
                                        {{price monthly_price currency=currency}}/{{t "month"}}
                                    </a>
                                {{/if}}
                                {{#if yearly_price}}
                                    <a class="gh-btn gh-primary-btn" href="#/portal/signup/{{id}}/yearly" data-portal="signup/{{id}}/yearly">
                                        {{price yearly_price currency=currency}}/{{t "year"}}
                                    </a>
                                {{/if}}
                            </div>

                            {{#if benefits}}
                                <ul class="gh-pricing-card-benefits">
                                    {{#foreach benefits as |benefit|}}
                                        <li>{{benefit}}</li>
                                    {{/foreach}}
                                </ul>
                            {{/if}}
                        </article>
                    {{/foreach}}
                </div>
            {{/if}}
        {{/get}}
    </div>
</section>
